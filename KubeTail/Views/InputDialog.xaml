<Window x:Class="KubeTail.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="160" Width="350" ResizeMode="NoResize"
        Background="#1E1E1E" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Foreground="#CCC" Margin="0,0,0,8"/>
        <TextBox x:Name="InputBox" Background="#333" Foreground="#CCC"
                 BorderThickness="0" Padding="6,4" FontSize="13"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Style="{StaticResource AccentButton}" Width="70"
                    Click="OK_Click" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Width="70"
                    IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
