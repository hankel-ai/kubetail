<Window x:Class="KubeTail.Views.ExclusionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Namespace Exclusions" Height="350" Width="400"
        Background="#1E1E1E" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,8">
            One pattern per line. Use * as wildcard.
            <LineBreak/>
            Example: openshift* excludes all namespaces starting with "openshift".
        </TextBlock>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Style="{StaticResource AccentButton}" Width="70"
                    Click="Save_Click" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="Cancel" Style="{StaticResource FlatButton}" Width="70"
                    IsCancel="True"/>
        </StackPanel>
        <TextBox x:Name="ExclusionBox" AcceptsReturn="True" TextWrapping="Wrap"
                 Background="#252526" Foreground="#CCC" BorderThickness="0"
                 Padding="8" FontFamily="Cascadia Mono,Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
